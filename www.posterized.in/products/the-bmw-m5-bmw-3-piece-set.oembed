e world.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eNote:\u003c\/strong\u003e Slight color variation may occur due to lighting and screen differences.\u003c\/p\u003e","brand":"Posterized","offers":[{"title":"A4","offer_id":51995797815592,"sku":null,"price":349.0,"currency_code":"INR","in_stock":true},{"title":"A3","offer_id":51995797848360,"sku":null,"price":399.0,"currency_code":"INR","in_stock":true},{"title":"13X19\"","offer_id":51995797881128,"sku":null,"price":449.0,"currency_code":"INR","in_stock":true}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0758\/7246\/9288\/files\/BMWW1.jpg?v=1781939664","url":"https:\/\/www.posterized.in\/products\/the-bmw-m5-bmw-3-piece-set","provider":"Posterized","version":"1.0","type":"link"}